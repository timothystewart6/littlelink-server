{
  "name": "littlelink-server",
  "version": "1.0.0",
  "description": "A server based on littlelink",
  "main": "app.js",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "node server.js",
    "build": "next build",
    "debug": "yarn start --inspect --inspect-port 9230",
    "start": "NODE_ENV=production node server.js",
    "test:e2e": "npx playwright test",
    "test:e2e:minimal": "bash e2e/minimal-env.sh",
    "test": "node --experimental-vm-modules ./node_modules/.bin/jest --passWithNoTests --env=jsdom",
    "lint": "eslint .",
    "lint:style": "stylelint ./src/**/*.css ./public/**/*.css",
    "lint:markdown": "markdownlint .github/*.md && markdownlint README.md",
    "ci": "yarn lint && yarn lint:style && yarn lint:markdown && yarn test"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-brands-svg-icons": "^6.7.2",
    "@fortawesome/free-regular-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.6",
    "compression": "^1.8.1",
    "express": "^4.21.2",
    "morgan": "^1.10.1",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.30",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx": "^0.1.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-promise": "^6.6.0",
    "eslint-plugin-react": "^7.37.5",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.8.2",
    "stylelint": "^16.25.0"
  }
}
